{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3008 --host=0.0.0.0",
    "dev:whatsapp": "tsx server/index.ts",
    "dev:admin": "vite admin-panel --port=3009 --host=0.0.0.0",
    "dev:all": "npx concurrently \"npm run dev:whatsapp\" \"npm run dev\" \"npm run dev:admin\"",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:admin": "vite build admin-panel",
    "build": "npm run build:client && npm run build:server && npm run build:admin",
    "start:prod": "NODE_ENV=production node dist/server/index.js",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^1.29.0",
    "@supabase/supabase-js": "^2.100.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/cors": "^2.8.19",
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/socket.io": "^3.0.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.14.0",
    "bull": "^4.16.5",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "instagram-private-api": "^1.46.1",
    "ioredis": "^5.10.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "pdf-parse": "^2.4.5",
    "pino": "^10.3.1",
    "qrcode-terminal": "^0.12.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0",
    "vite": "^6.2.0",
    "whatsapp-web.js": "^1.34.6",
    "archiver": "^7.0.1",
    "extract-zip": "^2.0.1",
    "@types/archiver": "^6.0.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/pdf-parse": "^1.1.5",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
